# ─── Application ─────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000
LOG_LEVEL=info
# MED-06 : adresse bind (127.0.0.1 derrière un proxy Nginx, 0.0.0.0 sinon)
HOST=0.0.0.0
API_PREFIX=/api

# ─── Base de données PostgreSQL ───────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=yobnate_colis
DB_USER=postgres
DB_PASSWORD=your_db_password_here

# ─── JWT — OBLIGATOIRE : 3 secrets distincts, min 32 caractères aléatoires ───
JWT_SECRET=changez_ce_secret_par_une_chaine_aleatoire_de_min_32_chars
JWT_REFRESH_SECRET=autre_secret_refresh_min_32_chars_different_du_jwt_secret
JWT_RESET_SECRET=autre_secret_reset_min_32_chars_different_des_deux_precedents
JWT_EXPIRES_IN=1h

# ─── CORS ────────────────────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:3000,http://localhost:8080

# ─── Cloudinary (upload images) ──────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ─── Email — SMTP (nodemailer) ────────────────────────────────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_smtp_user
SMTP_PASSWORD=your_smtp_password
MAIL_FROM=Yobnate Colis <noreply@votre-domaine.com>

# ─── Super admin — OBLIGATOIRE pour npm run seed ──────────────────────────────
# CRIT-01 : aucun fallback hardcodé — SUPER_ADMIN_EMAIL / SUPER_ADMIN_PASSWORD
# DOIVENT être définies pour que le compte super admin soit créé.
SUPER_ADMIN_EMAIL=admin@votre-domaine.com
SUPER_ADMIN_PASSWORD=VotreMotDePasse_Min12Chars!
SUPER_ADMIN_NOM=Admin
SUPER_ADMIN_PRENOM=Yobnate
