# Application
NODE_ENV=development
PORT=5000
API_PREFIX=/api

# Base de données PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=yobnate_colis
DB_USER=yobnate
DB_PASSWORD=change_me

# JWT (3 secrets distincts obligatoires)
JWT_SECRET=change_me_access_secret
JWT_REFRESH_SECRET=change_me_refresh_secret
JWT_RESET_SECRET=change_me_reset_secret
JWT_EXPIRES_IN=15m

# CORS
CORS_ORIGIN=http://localhost:3000

# Cloudinary (photos de colis / avatars)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Email (OTP, notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
MAIL_FROM="Yobnate Colis <no-reply@yobnate-colis.com>"

# Super admin initial (seeder)
SUPER_ADMIN_EMAIL=admin@yobnate-colis.com
SUPER_ADMIN_PASSWORD=change_me_strong_password
SUPER_ADMIN_NOM=Admin
SUPER_ADMIN_PRENOM=Yobnate
