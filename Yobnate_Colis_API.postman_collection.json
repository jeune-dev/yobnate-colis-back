{
  "info": {
    "_postman_id": "yobnate-colis-api-v2",
    "name": "Yobnate Colis API v2",
    "description": "Collection complète et corrigée — Auth, Client, Admin. Les scripts auto-sauvegardent les IDs et tokens après chaque création.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl",        "value": "http://localhost:5000", "type": "string" },
    { "key": "accessToken",    "value": "",                      "type": "string" },
    { "key": "refreshToken",   "value": "",                      "type": "string" },
    { "key": "userId",         "value": "",                      "type": "string" },
    { "key": "adminId",        "value": "",                      "type": "string" },
    { "key": "colisId",        "value": "",                      "type": "string" },
    { "key": "villeDepartId",  "value": "",                      "type": "string" },
    { "key": "villeArriveeId", "value": "",                      "type": "string" },
    { "key": "tarifId",        "value": "",                      "type": "string" },
    { "key": "factureId",      "value": "",                      "type": "string" },
    { "key": "paiementId",     "value": "",                      "type": "string" },
    { "key": "notifId",        "value": "",                      "type": "string" }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }]
  },
  "item": [

    {
      "name": "🔐 Auth",
      "item": [

        {
          "name": "Register — Inscription client",
          "event": [{
            "listen": "test",
            "script": {
              "type": "text/javascript",
              "exec": [
                "if (pm.response.code === 201) {",
                "  const r = pm.response.json();",
                "  pm.collectionVariables.set('userId', r.data?.utilisateur?.id ?? '');",
                "  console.log('✅ Inscription OK — userId:', r.data?.utilisateur?.id);",
                "} else {",
                "  console.error('❌', pm.response.json());",
                "}"
              ]
            }
          }],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/auth/register", "host": ["{{baseUrl}}"], "path": ["auth","register"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nom\": \"Diallo\",\n  \"prenom\": \"Mamadou\",\n  \"email\": \"mamadou.diallo@test.com\",\n  \"telephone\": \"771234567\",\n  \"password\": \"Password123!\"\n}"
            }
          }
        },

        {
          "name": "Login — Connexion client",
          "event": [{
            "listen": "test",
            "script": {
              "type": "text/javascript",
              "exec": [
                "if (pm.response.code === 200) {",
                "  const r = pm.response.json();",
                "  pm.collectionVariables.set('accessToken', r.data?.accessToken ?? '');",
                "  pm.collectionVariables.set('userId',      r.data?.utilisateur?.id ?? '');",
                "  // Le refreshToken est dans le cookie HttpOnly 'refreshToken'",
                "  const cookie = pm.cookies.get('refreshToken');",
                "  if (cookie) pm.collectionVariables.set('refreshToken', cookie);",
                "  console.log('✅ Login OK — accessToken sauvegardé');",
                "} else {",
                "  console.error('❌', pm.response.json());",
                "}"
              ]
            }
          }],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/auth/login", "host": ["{{baseUrl}}"], "path": ["auth","login"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"mamadou.diallo@test.com\",\n  \"password\": \"Password123!\"\n}"
            }
          }
        },

        {
          "name": "Login — Connexion Super Admin",
          "event": [{
            "listen": "test",
            "script": {
              "type": "text/javascript",
              "exec": [
                "if (pm.response.code === 200) {",
                "  const r = pm.response.json();",
                "  pm.collectionVariables.set('accessToken', r.data?.accessToken ?? '');",
                "  pm.collectionVariables.set('userId',      r.data?.utilisateur?.id ?? '');",
                "  const cookie = pm.cookies.get('refreshToken');",
                "  if (cookie) pm.collectionVariables.set('refreshToken', cookie);",
                "  console.log('✅ Login Admin OK — role:', r.data?.utilisateur?.role);",
                "} else {",
                "  console.error('❌', pm.response.json());",
                "}"
              ]
            }
          }],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/auth/login", "host": ["{{baseUrl}}"], "path": ["auth","login"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"Admin@yobante.com\",\n  \"password\": \"Admin@1234!\"\n}"
            }
          }
        },

        {
          "name": "Refresh Token — Renouveler l'access token",
          "event": [{
            "listen": "test",
            "script": {
              "type": "text/javascript",
              "exec": [
                "if (pm.response.code === 200) {",
                "  const r = pm.response.json();",
                "  pm.collectionVariables.set('accessToken', r.data?.accessToken ?? '');",
                "  const cookie = pm.cookies.get('refreshToken');",
                "  if (cookie) pm.collectionVariables.set('refreshToken', cookie);",
                "  console.log('✅ Token rafraîchi');",
                "}"
              ]
            }
          }],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/auth/refresh-token", "host": ["{{baseUrl}}"], "path": ["auth","refresh-token"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
            }
          }
        },

        {
          "name": "Logout — Déconnexion",
          "event": [{
            "listen": "test",
            "script": {
              "type": "text/javascript",
              "exec": [
                "if (pm.response.code === 200) {",
                "  pm.collectionVariables.set('accessToken', '');",
                "  pm.collectionVariables.set('refreshToken', '');",
                "  console.log('✅ Déconnecté — tokens effacés');",
                "}"
              ]
            }
          }],
          "request": {
            "method": "POST",
            "header": [],
            "url": { "raw": "{{baseUrl}}/auth/logout", "host": ["{{baseUrl}}"], "path": ["auth","logout"] },
            "body": { "mode": "raw", "raw": "" }
          }
        },

        {
          "name": "Forgot Password — Mot de passe oublié",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/auth/forgot-password", "host": ["{{baseUrl}}"], "path": ["auth","forgot-password"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"mamadou.diallo@test.com\"\n}"
            }
          }
        },

        {
          "name": "Reset Password — Réinitialiser le mot de passe",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/auth/reset-password", "host": ["{{baseUrl}}"], "path": ["auth","reset-password"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"mamadou.diallo@test.com\",\n  \"code\": \"123456\",\n  \"newPassword\": \"NewPassword123!\"\n}"
            }
          }
        },

        {
          "name": "Change Password — Changer le mot de passe",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/auth/change-password", "host": ["{{baseUrl}}"], "path": ["auth","change-password"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"oldPassword\": \"Password123!\",\n  \"newPassword\": \"NewPassword456@\"\n}"
            }
          }
        }

      ]
    },

