                "  pm.collectionVariables.set('colisId',   r.data?.colis?.id   ?? '');",
                "  pm.collectionVariables.set('factureId', r.data?.facture?.id ?? '');",
                "  console.log('✅ Colis créé — colisId:', r.data?.colis?.id);",
                "  console.log('✅ Facture générée — factureId:', r.data?.facture?.id);",
                "} else {",
                "  console.error('❌', pm.response.json());",
                "}"
              ]
            }
          }],
          "request": {
            "method": "POST",
            "header": [],
            "url": { "raw": "{{baseUrl}}/client/colis", "host": ["{{baseUrl}}"], "path": ["client","colis"] },
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "expediteurNom",          "value": "Mamadou Diallo",          "type": "text" },
                { "key": "expediteurTelephone",    "value": "771234567",               "type": "text" },
                { "key": "villeDepartId",           "value": "{{villeDepartId}}",       "type": "text", "description": "UUID de la ville de départ" },
                { "key": "destinataireNom",         "value": "Fatoumata Balde",         "type": "text" },
                { "key": "destinataireTelephone",   "value": "769876543",               "type": "text" },
                { "key": "villeArriveeId",          "value": "{{villeArriveeId}}",      "type": "text", "description": "UUID de la ville d'arrivée" },
                { "key": "adresseLivraison",        "value": "Quartier Almamya, Rue KA-012", "type": "text" },
                { "key": "typeColis",               "value": "standard",               "type": "text", "description": "standard | express | fragile" },
                { "key": "poids",                   "value": "2.5",                    "type": "text" },
                { "key": "valeurDeclaree",          "value": "50000",                  "type": "text" },
                { "key": "description",             "value": "Vêtements et accessoires", "type": "text" },
                { "key": "photos",                  "type": "file", "src": "",         "disabled": true, "description": "Optionnel — max 5 fichiers (png/jpeg, 5 Mo chacun)" }
              ]
            }
          }
        },

