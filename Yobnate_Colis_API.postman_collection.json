    {
      "name": "🔐 Auth",
      "item": [
        {
          "name": "Inscription (Register)",
          "event": [{
            "listen": "test",
            "script": {
              "type": "text/javascript",
              "exec": [
                "if (pm.response.code === 201) {",
                "  const r = pm.response.json();",
                "  pm.collectionVariables.set('userId', r.data?.utilisateur?.id || '');",
                "  console.log('✅ Inscription OK — connectez-vous maintenant pour obtenir le token');",
                "}"
              ]
            }
          }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/auth/register", "host": ["{{baseUrl}}"], "path": ["auth", "register"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nom\": \"Diallo\",\n  \"prenom\": \"Mamadou\",\n  \"email\": \"mamadou.diallo@test.com\",\n  \"telephone\": \"771234567\",\n  \"password\": \"Password123!\"\n}"
            }
          }
        },
        {
          "name": "Connexion (Login)",
          "event": [{
            "listen": "test",
            "script": {
              "type": "text/javascript",
              "exec": [
                "if (pm.response.code === 200) {",
                "  const r = pm.response.json();",
                "  pm.collectionVariables.set('accessToken',  r.data?.accessToken  || '');",
                "  pm.collectionVariables.set('refreshToken', r.data?.refreshToken || '');",
                "  pm.collectionVariables.set('userId',       r.data?.utilisateur?.id     || '');",
                "  console.log('✅ Login OK — token sauvegardé');",
                "}"
              ]
            }
          }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/auth/login", "host": ["{{baseUrl}}"], "path": ["auth", "login"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"mamadou.diallo@test.com\",\n  \"password\": \"Password123!\"\n}"
            }
          }
        },
        {
          "name": "Connexion Admin (Super Admin)",
          "event": [{
            "listen": "test",
            "script": {
              "type": "text/javascript",
              "exec": [
                "if (pm.response.code === 200) {",
                "  const r = pm.response.json();",
                "  pm.collectionVariables.set('accessToken',  r.data?.accessToken  || '');",
                "  pm.collectionVariables.set('refreshToken', r.data?.refreshToken || '');",
                "  pm.collectionVariables.set('userId',       r.data?.utilisateur?.id     || '');",
                "  console.log('✅ Login Admin OK');",
                "}"
              ]
            }
          }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/auth/login", "host": ["{{baseUrl}}"], "path": ["auth", "login"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@yobante.com\",\n  \"password\": \"Admin@2024!\"\n}"
            }
          }
        },
        {
          "name": "Rafraîchir le token (Refresh Token)",
          "event": [{
            "listen": "test",
            "script": {
              "type": "text/javascript",
              "exec": [
                "if (pm.response.code === 200) {",
                "  const r = pm.response.json();",
                "  pm.collectionVariables.set('accessToken',  r.data?.accessToken  || '');",
                "  pm.collectionVariables.set('refreshToken', r.data?.refreshToken || '');",
                "}"
              ]
            }
          }],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/auth/refresh-token", "host": ["{{baseUrl}}"], "path": ["auth", "refresh-token"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
            }
